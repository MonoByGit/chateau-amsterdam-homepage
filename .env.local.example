DATABASE_URL=postgresql://postgres:postgres@localhost:5433/chateau_dev

AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto

# Shopify Storefront API — cart + checkout hand-off (lib/shopify/, lib/cart/).
# Leave empty until Dusty provides them: the site falls back to a direct
# per-product Shopify link (see components/add-to-cart-button.tsx) instead of
# breaking when these are unset.
# Get a Storefront API access token: Shopify admin (chateau.amsterdam) →
# Instellingen → Apps en verkoopkanalen → Apps ontwikkelen → maak een app aan
# → Storefront API → "Storefront API access token aanmaken".
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=
# Optional: Storefront API version, defaults to 2025-10 if unset (lib/shopify/client.ts).
SHOPIFY_API_VERSION=

# Umami analytics (self-hosted, cookieless). Ask Dusty for the instance URL
# and create a "website" for chateau.amsterdam to get the website ID.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
